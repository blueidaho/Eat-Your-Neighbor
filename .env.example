# Hostinger email (SMTP) — used to notify you of new waitlist signups
# Host/port defaults below match Hostinger's standard SMTP settings; override
# only if your hosting panel shows something different.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=admin@eatyourneighbor.com
SMTP_PASSWORD=
# Optional: where signup notifications are sent. Defaults to SMTP_USER.
NOTIFY_EMAIL=admin@eatyourneighbor.com
