# Mailchimp Marketing API
# Found under Account > Extras > API keys. The key's suffix (after the dash)
# is your server prefix, e.g. a key ending in "-us21" means MAILCHIMP_SERVER_PREFIX=us21
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=
# Audience/List ID: Audience > Settings > Audience name and defaults
MAILCHIMP_AUDIENCE_ID=
